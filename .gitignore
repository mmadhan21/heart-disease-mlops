# =============================================================
# Heart Disease MLOps Pipeline
# File    : .gitignore
# =============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────
mlops_env/
venv/
env/
.env/
.venv/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── MLflow ────────────────────────────────────────────────────
# Uncomment below if you do NOT want to commit run logs
# mlruns/

# ── Trained models (large binary files) ──────────────────────
# Keep best_model.pkl committed for Docker build in CI
# Uncomment to exclude:
# models/*.pkl

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.spyproject/

# ── Test cache ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
test-results/

# ── Docker ───────────────────────────────────────────────────
# (nothing to ignore — Dockerfile is committed)

# ── Secrets / credentials ─────────────────────────────────────
.env
*.pem
*.key
secrets/
# Extra ignores
heart-api.tar
*.tar
mlops_env/
__pycache__/
*.pyc
.ipynb_checkpoints/
api_requests.log

